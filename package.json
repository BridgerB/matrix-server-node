{
  "name": "matrix-server-node",
  "version": "0.0.1",
  "description": "Matrix homeserver implementation in Node.js",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "format": "biome format --write src",
    "lint": "biome check src",
    "check": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --watch src/index.ts"
  },
  "license": "Unlicense",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "mariadb": "^3.5.1",
    "pg": "^8.19.0"
  }
}
